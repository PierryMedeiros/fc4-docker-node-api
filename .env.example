# Copie para .env antes de subir o ambiente:  cp .env.example .env
# Valores funcionais para desenvolvimento local — NÃO usar em produção real.

# Porta em que a API escuta (mapeada para o host).
PORT=3000

# Conexão com o PostgreSQL. DB_HOST=db aponta para o serviço `db` do compose.
DB_HOST=db
DB_PORT=5432
DB_USER=flags
DB_PASSWORD=flags_local_password
DB_NAME=flags
